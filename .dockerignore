# =============================================================================
# ReceiptLens — .dockerignore
# =============================================================================

# Version control
.git/
.gitignore

# Python artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
tests/

# Linting & type checking
.ruff_cache/
.mypy_cache/

# IDE / OS
.DS_Store
Thumbs.db
*.swp
*~

# Local workflow
.mimocode/
.hermes/

# Documentation (not needed at runtime)
docs/
specs/
examples/
analysis/
CHANGELOG.md
README.md

# CI / CD
.github/
.gitlab-ci.yml
*.yml
*.yaml

# Docker (don't include Dockerfiles in context)
infra/
Dockerfile
.dockerignore
docker-compose*.yml

# Node (if any frontend tooling is added later)
node_modules/
package.json
package-lock.json

# Railway / deployment configs (not needed inside the image)
railway.toml
railway.json
fly.toml
